# ── Recall.ai (meeting bot) ──
RECALLAI_API_KEY=e529...your key
RECALL_REGION=ap-northeast-1
NGROK_URL=https://xxxx.ngrok-free.app        # update WHEN YOU ngrok restart

# ── LLMs ──
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=AQ..
ANTHROPIC_API_KEY=            # optional, fine to leave empty

# ── Supabase ──
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_KEY=sb_secret_...    # the secret/service key (backend only)

# ── Email invites (Gmail SMTP) ──
GMAIL_ADDRESS=youraddress@gmail.com
GMAIL_APP_PASSWORD=abcdefghijklmnop          # 16-char App Password, NOT your login password

# ── Security ──
APP_ENCRYPTION_KEY=f1...      # you have this ✓

# ── Legacy (unused now, harmless to keep) ──
AZURE_SPEECH_KEY=...
AZURE_SPEECH_REGION=...
